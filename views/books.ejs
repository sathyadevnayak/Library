<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>All Books</title>
    <link rel="stylesheet" href="/styles.css">
</head>
<body>
    <div class="sidebar">
        <h2>library</h2>
        <a href="/dashboard">Dashboard</a>
        <a href="/books">books</a>
        <a href="/borrowed">Borrowed Books</a>
        <a href="/visits">Library Visits</a>
        <a href="/students">Students</a>
        <a href="/logout">logout</a>
    </div>
    <div class="main-class">
        <div class="page-header">
        <h1>Books Management</h1>
        <a href="/addbooks" class="primary-btn">+ add new book</a>
    </div>
        <table>
            <tr>
                <th>ID</th>
                <th>Title</th>
                <th>Author</th>
                <th>Quantity</th>
                <th>Actions</th>
            </tr>
            <% books.forEach(book=>{ %>
            <tr>
                <td><%= book.id %></td>
                <td><%= book.title %></td>
                <td><%= book.author %></td>
                <td><%= book.quantity %></td>
                <td>
                    <a href="/books/edit/<%= book.id %>" class="edit-btn">Edit</a>
                    <a href="/books/delete/<%= book.id %>"class="delete-btn"onclick="return confirm('Delete this book?')">Delete</a>
                </td>
                <%})%>
            </tr>
        </table>
    </div>
</body>
</html>